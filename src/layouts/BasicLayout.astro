---
import { site } from "../config";
import HeadBase from "../components/HeadBase.astro";
import { Image } from "astro:assets";
import NavBar from "../components/NavBar.astro";

export interface Props {
  coverImage?: ImageMetadata;
}

const { coverImage } = Astro.props;
---

<html lang={site.lang}>
  <head>
    <HeadBase />
  </head>
  <body>
    <NavBar />
    <div class="page">
      {
        coverImage && (
          <div class:list={['cover-image', site.coverImageStyle]}>
            <Image src={coverImage} alt="" />
          </div>
        )
      }
      <div class="page-content">
        <aside class="part-left">
          <slot name="part-left"></slot>
        </aside>

        <div class="part-center">
          <slot name="part-center"></slot>
        </div>

        <aside class="part-right">
          <slot name="part-right"></slot>
        </aside>
      </div>
    </div>
  </body>
</html>

<style lang="stylus">
  body {
    background-color: var(--background);
    font-family: var(--font-sans);
    margin: 0;
    min-height: 100vh;
  }

  .page {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-y: auto;

    parallax() {
      transform-style: preserve-3d;
      perspective: 1px;
    }

    &:has(.parallax) {
      parallax();
    }
    &:has(.half-parallax) {
      parallax();
    }
  }

  .cover-image {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 0 0 auto;

    &.static {
      height: 100vh;
    }

    parallax() {
      transform: translateZ(-1px) scale(2.05);
    }

    &.parallax {
      height: 100vh;
      parallax();
    }

    &.half-parallax {
      height: 50vh;
      transform-origin: 50% 100%;
      parallax();
    }

    img {
      position: absolute;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .page-content {
    display: flex;
    flex-direction: row;
    width: 100%;
    padding: 1.5rem;
    box-sizing: border-box;
    background-color: var(--background);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow: 0 -4px 6px -1px var(--shadow);
    margin-top: -@border-radius;
    z-index: 10;

    padding-top: 72px;
  }

  .part-left {
    flex: 0 0 20%;
    padding-right: 1rem;
  }

  .part-center {
    display: flex;
    flex-direction: column;
    align-items: stretch;

    flex: 1 1 60%;
    max-width: 60%;
    padding: 0 1rem;
  }

  .part-right {
    flex: 0 0 20%;
    padding-left: 1rem;
  }

  @media (max-width: 768px) {
    .page-content {
      flex-direction: column;
    }

    .sidebar-left,
    .sidebar-right {
      display: none;
    }
  }
</style>
