---
import PostContent from '../components/PostContent.astro';

import type { CollectionEntry } from 'astro:content';
import BasicLayout from './BasicLayout.astro';

export type Props = {
  post: CollectionEntry<'blog'>;
};

const { coverImage } = Astro.props.post.data;

const layoutProps = {
  coverImage,
}
---

<BasicLayout {...layoutProps}>
  <Fragment slot="part-center">
    <main class="card article-content-card">
      <PostContent post={Astro.props.post} />
    </main>
  </Fragment>
</BasicLayout>

<style lang="stylus">
  .card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -2px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }

  :global(.page:has(.cover-image) .article-content-card) {
    margin-top: calc(-1.5rem - 64px - 48px);
  }

  .article-content-card {
    padding: 32px;
  }
</style>
