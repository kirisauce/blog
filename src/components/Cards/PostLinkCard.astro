---
import type { CollectionEntry } from 'astro:content';
import { blogurl } from '../../utils/url';
import { Image } from 'astro:assets';
import Label from '../Label.astro';
import Meta from '../MetaWidgets/Meta.astro';
import TimeMeta from '../MetaWidgets/TimeMeta.astro';
import TagsMeta from '../MetaWidgets/TagsMeta.astro';

export interface Props {
  post: CollectionEntry<'blog'>;
  updateDate?: Date;
  pubDate?: Date;
  description?: string;
}

const { post, updateDate, pubDate, description } = Astro.props;
const { category, tags } = post.data;
---

<a href={blogurl.with(post.id)} class="card link-card">
  <div class="content">
    <Label style="font-size:28px;">{post.data.title}</Label>
    <div class="metas">
      <TimeMeta icon="mdi:calendar-edit-outline" time={updateDate} />
      <TimeMeta icon="mdi:calendar-outline" time={pubDate} />
      <Meta icon="mdi:category-outline" content={category} />
      <TagsMeta tags={tags} />
    </div>
    <div class="description">{description}</div>
  </div>
  <div class="cover">
    {
      post.data.coverImage && (
        <Image
          src={post.data.coverImage}
          alt={post.data.coverImageAlt ?? 'Cover Image'}
        />
      )
    }
  </div>
</a>

<style lang="stylus">
  .link-card {
    display: flex;
    flex-direction: row;
    height: 200px;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-sans);
    gap: 16px;
  }

  .content {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    width: 0;
  }

  .cover {
    position: relative;
    flex-shrink: 0;
    width: auto;
    max-width: 40%;
    display: flex;
    flex-direction: row;
    align-items: stretch;

    >img {
      height: 100%;
      width: 100%;
      flex: 1 0 auto
      object-fit: cover;
      border-radius: 16px;
      border: 1px solid var(--border);
    }
  }

  .description {
    flex: 1 0 0;
    height: 0;
    width: 100%;
    white-space: pre-line;
    overflow: clip;
  }
</style>
