---
import Icon from './Icon.astro';
import { navbar, site } from '../config';

import {} from 'astro:config/client'
---

<div class="nav-container">
  <nav>
    <div class="nav-part">
      <slot name="left">
        <a href={Astro.site ?? '/'} class="row">{navbar.icon && <Icon src={navbar.icon} />}{navbar.homeText ?? site.title}</a>
      </slot>
    </div>
    <div class="nav-part">
      <slot name="center" />
    </div>
    <div class="nav-part">
      <slot name="right" />
    </div>
  </nav>
</div>

<style lang="stylus">
  .nav-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    z-index: 500;

    display: flex;
    flex-direction: column;
    align-items: center;
  }

  nav {
    position: relative;
    flex: 0 0 56px;
    width: 80%;
    backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px -6px var(--shadow);
    font-family: var(--font-sans-serif);

    R = 20px;
    border-bottom-left-radius: R;
    border-bottom-right-radius: R;

    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    box-sizing: border-box;

    &::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0.92;
      z-index: -1;
      background-color: var(--nav);
      border-bottom-left-radius: R;
      border-bottom-right-radius: R;
    }
  }

  a {
    text-decoration: none;
    color: var(--primary);
    font-weight: bold;
    font-family: var(--font-monospace);
    svg {
      font-size: 20px;
    }
  }

  svg {
    position: relative;
    top: -0.1em;
  }

  .row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
  }
</style>
