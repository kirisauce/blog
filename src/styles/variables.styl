// Palette Colors

@import './color'

:root
  for name, color-list in palette
    {'--' + name}: color-list[0]
  color-scheme: light
:root.dark
  for name, color-list in palette
    {'--' + name}: color-list[1]
  color-scheme: dark

:root
  --font-sans: 'Roboto', 'Noto Sans', sans-serif
  font: var(--font-sans)

  // Expressive fast spatial
  --expressive-fast-spatial: 350ms cubic-bezier(0.42, 1.67, 0.21, 0.90)

  // Expressive default spatial
  --expressive-default-spatial: 500ms cubic-bezier(0.38, 1.21, 0.22, 1.00)

  // Expressive slow spatial
  --expressive-slow-spatial: 650ms cubic-bezier(0.39, 1.29, 0.35, 0.98)

  // Expressive fast effects
  --expressive-fast-effects: 150ms cubic-bezier(0.31, 0.94, 0.34, 1.00)

  // Expressive default effects
  --expressive-default-effects: 200ms cubic-bezier(0.34, 0.80, 0.34, 1.00)

  // Expressive slow effects
  --expressive-slow-effects: 300ms cubic-bezier(0.34, 0.88, 0.34, 1.00)

  // Standard fast spatial
  --standard-fast-spatial: 350ms cubic-bezier(0.27, 1.06, 0.18, 1.00)

  // Standard default spatial
  --standard-default-spatial: 500ms cubic-bezier(0.27, 1.06, 0.18, 1.00)

  // Standard slow spatial
  --standard-slow-spatial: 750ms cubic-bezier(0.27, 1.06, 0.18, 1.00)

  // Standard fast effects
  --standard-fast-effects: 150ms cubic-bezier(0.31, 0.94, 0.34, 1.00)

  // Standard default effects
  --standard-default-effects: 200ms cubic-bezier(0.34, 0.80, 0.34, 1.00)

  // Standard slow effects
  --standard-slow-effects: 300ms cubic-bezier(0.34, 0.88, 0.34, 1.00)