hue = var(--color-hue, 0)

palette = {
  surface-hover: oklch(92% 16% hue) oklch(24% 14% hue)
  primary:    oklch(55% 85% hue) oklch(90% 70% hue)
  background: oklch(98% 8% hue)  oklch(10% 5% hue)
  surface:    oklch(96% 12% hue) oklch(15% 5% hue)
  border:     oklch(85% 15% hue) oklch(35% 15% hue)
  text:       oklch(20% 20% hue) oklch(92% 20% hue)
  text-muted: oklch(45% 20% hue) oklch(70% 20% hue)
  nav:        oklch(94% 14% hue) oklch(20% 10% hue)

  shadow: oklch(0% 0% hue \/ 0.08) oklch(0% 0% hue \/ 0.3)
}